{
  "id": "mlb_scores",
  "name": "MLB Scores",
  "version": "1.8.0",
  "description": "Fast live MLB scores with favorite-team page triggers for Vestaboard",
  "author": "Christopher Louie",
  "repository": "https://github.com/louwii17/fiestaboard-plugin--mlb-scores",
  "documentation": "README.md",
  "icon": "trophy",
  "category": "data",
  "min_refresh_seconds": 10,
  "supports_triggers": true,
  "fiestaboard_version": ">=7.0.0",
  "settings_schema": {
    "type": "object",
    "properties": {
      "enabled": {
        "type": "boolean",
        "title": "Enable MLB Scores",
        "default": false
      },
      "favorite_teams": {
        "type": "array",
        "title": "Favorite MLB teams",
        "description": "Choose the teams whose live games should take over the board",
        "default": ["TOR"],
        "items": {
          "type": "string",
          "enum": ["ARI", "ATH", "ATL", "BAL", "BOS", "CHC", "CWS", "CIN", "CLE", "COL", "DET", "HOU", "KC", "LAA", "LAD", "MIA", "MIL", "MIN", "NYM", "NYY", "PHI", "PIT", "SD", "SEA", "SF", "STL", "TB", "TEX", "TOR", "WSH"]
        },
        "uniqueItems": true
      },
      "favorites_only": {
        "type": "boolean",
        "title": "Only show favorite teams",
        "description": "Hide other MLB games from normal page data",
        "default": false
      },
      "trigger_page_id": {
        "type": "string",
        "title": "Live game page",
        "description": "Existing template page shown automatically while a favorite team is live and during the final-score hold",
        "ui:widget": "page-picker"
      },
      "final_display_seconds": {
        "type": "integer",
        "title": "Final score display time",
        "description": "Seconds to keep the live game page showing FINAL before returning to the current schedule or manual page",
        "default": 120,
        "minimum": 10,
        "maximum": 900
      },
      "max_games": {
        "type": "integer",
        "title": "Maximum games",
        "default": 3,
        "minimum": 1,
        "maximum": 10
      },
      "timezone": {
        "type": "string",
        "title": "Timezone",
        "default": "America/Toronto",
        "ui:widget": "timezone"
      },
      "refresh_seconds": {
        "type": "integer",
        "title": "Live refresh interval",
        "description": "Seconds between checks near first pitch and during a live game",
        "default": 10,
        "minimum": 10,
        "maximum": 300
      },
      "outs_indicator_on": {
        "type": "string",
        "title": "Recorded out marker",
        "description": "One character, {0} for blank, or color code {63}-{71} used for each recorded out",
        "default": "{69}",
        "minLength": 1,
        "maxLength": 4
      },
      "outs_indicator_off": {
        "type": "string",
        "title": "Open out marker",
        "description": "One character, {0} for blank, or color code {63}-{71} used for each unrecorded out",
        "default": ".",
        "minLength": 1,
        "maxLength": 4
      },
      "base_indicator_on": {
        "type": "string",
        "title": "Occupied base marker",
        "description": "One character, {0} for blank, or color code {63}-{71} used for an occupied base",
        "default": "{65}",
        "minLength": 1,
        "maxLength": 4
      },
      "base_indicator_off": {
        "type": "string",
        "title": "Empty base marker",
        "description": "One character, {0} for blank, or color code {63}-{71} used for an empty base",
        "default": ".",
        "minLength": 1,
        "maxLength": 4
      }
    }
  },
  "env_vars": [
    {
      "name": "MLB_SCORES_ENABLED",
      "required": false,
      "default": "false",
      "description": "Enable MLB Scores"
    }
  ],
  "variables": {
    "groups": {
      "latest": {"label": "Top Game"},
      "display": {"label": "Display"}
    },
    "simple": {
      "game_id": {"description": "Stable MLB game identifier", "type": "string", "max_length": 12, "group": "latest", "example": "777123"},
      "state": {"description": "Normalized game state", "type": "string", "max_length": 12, "group": "latest", "example": "live"},
      "status": {"description": "MLB game status", "type": "string", "max_length": 20, "group": "latest", "example": "In Progress"},
      "phase": {"description": "Full game phase such as BOTTOM 1ST or FINAL", "type": "string", "max_length": 12, "group": "latest", "example": "BOTTOM 1ST"},
      "phase_short": {"description": "Compact game phase such as BOT 1ST or FINAL", "type": "string", "max_length": 12, "group": "latest", "example": "BOT 1ST"},
      "away_short": {"description": "Away team abbreviation", "type": "string", "max_length": 4, "group": "latest", "example": "TOR"},
      "away_name": {"description": "Away team full name", "type": "string", "max_length": 30, "group": "latest", "example": "Toronto Blue Jays"},
      "away_nickname": {"description": "Away team name without its city", "type": "string", "max_length": 16, "group": "latest", "example": "Blue Jays"},
      "away_score": {"description": "Away team score", "type": "number", "max_length": 3, "group": "latest", "example": "4"},
      "away_color": {"description": "Away franchise color tile", "type": "string", "max_length": 4, "group": "display", "example": "{67}"},
      "away_result_color": {"description": "Away win/loss color tile", "type": "string", "max_length": 4, "group": "display", "example": "{66}"},
      "home_short": {"description": "Home team abbreviation", "type": "string", "max_length": 4, "group": "latest", "example": "NYY"},
      "home_name": {"description": "Home team full name", "type": "string", "max_length": 30, "group": "latest", "example": "New York Yankees"},
      "home_nickname": {"description": "Home team name without its city", "type": "string", "max_length": 16, "group": "latest", "example": "Yankees"},
      "home_score": {"description": "Home team score", "type": "number", "max_length": 3, "group": "latest", "example": "3"},
      "home_color": {"description": "Home franchise color tile", "type": "string", "max_length": 4, "group": "display", "example": "{67}"},
      "home_result_color": {"description": "Home win/loss color tile", "type": "string", "max_length": 4, "group": "display", "example": "{63}"},
      "inning_half": {"description": "TOP, MIDDLE, BOTTOM, or END", "type": "string", "max_length": 6, "group": "latest", "example": "TOP"},
      "inning_half_short": {"description": "Compact inning half: TOP, MID, BOT, or END", "type": "string", "max_length": 3, "group": "latest", "example": "BOT"},
      "inning_number": {"description": "Current inning number", "type": "number", "max_length": 2, "group": "latest", "example": "7"},
      "inning_ordinal": {"description": "Current inning ordinal", "type": "string", "max_length": 4, "group": "latest", "example": "7TH"},
      "outs": {"description": "Current number of outs", "type": "number", "max_length": 1, "group": "latest", "example": "1"},
      "outs_text": {"description": "Board-ready outs", "type": "string", "max_length": 6, "group": "display", "example": "1 OUT"},
      "outs_indicator": {"description": "Three-position outs indicator using the configured recorded and open markers", "type": "string", "max_length": 12, "group": "display", "example": "{69}.."},
      "first_base_occupied": {"description": "Whether a runner occupies first base", "type": "boolean", "max_length": 5, "group": "latest", "example": true},
      "second_base_occupied": {"description": "Whether a runner occupies second base", "type": "boolean", "max_length": 5, "group": "latest", "example": false},
      "third_base_occupied": {"description": "Whether a runner occupies third base", "type": "boolean", "max_length": 5, "group": "latest", "example": true},
      "first_base_indicator": {"description": "Configured occupied or empty marker for first base", "type": "string", "max_length": 4, "group": "display", "example": "{65}"},
      "second_base_indicator": {"description": "Configured occupied or empty marker for second base", "type": "string", "max_length": 4, "group": "display", "example": "."},
      "third_base_indicator": {"description": "Configured occupied or empty marker for third base", "type": "string", "max_length": 4, "group": "display", "example": "{65}"},
      "inning_info": {"description": "Board-ready inning and outs", "type": "string", "max_length": 15, "group": "display", "example": "TOP 7 1 OUT"},
      "formatted": {"description": "Board-ready score line", "type": "string", "max_length": 22, "group": "display", "example": "TOR  4-3  NYY"},
      "progress": {"description": "Board-ready game progress", "type": "string", "max_length": 22, "group": "display", "example": "TOP 7TH"},
      "game_count": {"description": "Number of returned games", "type": "number", "max_length": 2, "group": "display", "example": "5"},
      "last_updated": {"description": "UTC fetch timestamp", "type": "string", "max_length": 32, "group": "display", "example": "2026-07-14T12:00:00Z"}
    },
    "arrays": {
      "games": {
        "label_field": "formatted",
        "item_fields": ["game_id", "state", "status", "phase", "phase_short", "date", "time", "away_short", "away_name", "away_nickname", "away_score", "away_color", "away_result_color", "home_short", "home_name", "home_nickname", "home_score", "home_color", "home_result_color", "inning_half", "inning_half_short", "inning_number", "inning_ordinal", "outs", "outs_text", "outs_indicator", "first_base_occupied", "second_base_occupied", "third_base_occupied", "first_base_indicator", "second_base_indicator", "third_base_indicator", "inning_info", "favorite", "formatted", "progress"]
      }
    }
  },
  "max_lengths": {
    "games.*.formatted": 22,
    "games.*.progress": 22,
    "games.*.away_short": 4,
    "games.*.home_short": 4,
    "games.*.inning_info": 15
  },
  "demo": {
    "flagship": {
      "name": "MLB Scores Demo",
      "template": ["MLB SCORES", "{{mlb_scores.formatted}}", "{{mlb_scores.progress}}", "", "", "{{mlb_scores.game_count}} GAMES"],
      "line_metadata": [{"alignment": "center", "wrap": false}, {"alignment": "left", "wrap": false}, {"alignment": "center", "wrap": false}, {"alignment": "left", "wrap": false}, {"alignment": "left", "wrap": false}, {"alignment": "center", "wrap": false}]
    },
    "note": {
      "name": "MLB Scores Note Demo",
      "template": ["{{mlb_scores.inning_info}}", "{{mlb_scores.away_color}} {{mlb_scores.away_nickname}} {{mlb_scores.away_score}}", "{{mlb_scores.home_color}} {{mlb_scores.home_nickname}} {{mlb_scores.home_score}}"],
      "line_metadata": [{"alignment": "left", "wrap": false}, {"alignment": "left", "wrap": false}, {"alignment": "left", "wrap": false}]
    }
  }
}
